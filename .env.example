# ============================================================================
# Kehrnel Runtime - Environment Example
# ============================================================================

# ----------------------------------------------------------------------------
# 1) HDL core/control-plane (single source of truth)
# Used for:
# - resolving tenant DB credentials from bindings_ref
# - persisting synthetic job history
# ----------------------------------------------------------------------------
CORE_MONGODB_URL=
CORE_DATABASE_NAME=hdl_core
KEHRNEL_JOBS_COLLECTION=synthetic_data_jobs

# Required for encrypted environment_secrets resolver:
ENV_SECRETS_KEY=

# Required resolver binding (strict mode):
KEHRNEL_BINDINGS_RESOLVER=kehrnel.integrations.hdl.bindings_resolver:resolve_hdl_bindings

# Optional collections where env metadata is stored (default: teams,users,workspaces)
# KEHRNEL_HDL_ENV_METADATA_COLLECTIONS=teams,users,workspaces

# ----------------------------------------------------------------------------
# 2) API security and traffic controls
# ----------------------------------------------------------------------------
KEHRNEL_AUTH_ENABLED=false
KEHRNEL_API_KEYS=
KEHRNEL_CORS_ORIGINS=
KEHRNEL_RATE_LIMIT=60

# ----------------------------------------------------------------------------
# 3) Runtime behavior
# ----------------------------------------------------------------------------
KEHRNEL_DEBUG=false
KEHRNEL_REGISTRY_PATH=.kehrnel_registry.json
# KEHRNEL_STRATEGY_PATHS=./src/kehrnel/engine/strategies
KEHRNEL_API_HOST=0.0.0.0
KEHRNEL_API_PORT=8080
KEHRNEL_API_RELOAD=false

# ----------------------------------------------------------------------------
# 4) File/path safety switches (recommended for production)
# ----------------------------------------------------------------------------
KEHRNEL_ALLOW_LOCAL_FILE_INPUTS=false
KEHRNEL_ALLOW_ABSOLUTE_CONFIG_PATHS=false

# ----------------------------------------------------------------------------
# 5) Mongo TLS (optional; keep strict defaults)
# ----------------------------------------------------------------------------
KEHRNEL_MONGO_TLS_ALLOW_INVALID_CERTS=false
# KEHRNEL_MONGO_TLS_CA_FILE=
