# ============================================================================
# Kehrnel Runtime - Environment Example
# ============================================================================

# ----------------------------------------------------------------------------
# 1) HDL core/control-plane (single source of truth)
# Used for:
# - resolving tenant DB credentials from bindings_ref
# - persisting synthetic job history
# ----------------------------------------------------------------------------
MONGODB_URI=
CORE_MONGODB_URL=
DB_BINDINGS='{"db":{"provider":"mongodb","uri":"<CONNECTION_STRING>","database":"hdl_core"}}'
CORE_DATABASE_NAME=hdl_core
KEHRNEL_JOBS_COLLECTION=synthetic_data_jobs

# Required for encrypted environment_secrets resolver:
ENV_SECRETS_KEY=

# Optional: explicit resolver (auto-detected when ENV_SECRETS_KEY + CORE_MONGODB_URL + CORE_DATABASE_NAME are set).
# KEHRNEL_BINDINGS_RESOLVER=kehrnel.engine.core.integrations.hdl.bindings_resolver:resolve_hdl_bindings

# Optional collections where env metadata is stored (default: teams,users,workspaces)
# KEHRNEL_HDL_ENV_METADATA_COLLECTIONS=teams,users,workspaces

# ----------------------------------------------------------------------------
# 2) API security and traffic controls
# ----------------------------------------------------------------------------
KEHRNEL_AUTH_ENABLED=true
KEHRNEL_API_KEYS=
# Optional subset of KEHRNEL_API_KEYS allowed for privileged admin routes.
# If empty, KEHRNEL_API_KEYS is used for admin access too.
KEHRNEL_ADMIN_API_KEYS=
# Optional per-key environment authorization map (JSON):
# {"keyA":["env-dev"],"keyB":"*"}
KEHRNEL_API_KEY_ENV_SCOPES=
# Optional fallback if no per-key map is set.
# KEHRNEL_DEFAULT_ENV_ID=env-dev
KEHRNEL_CORS_ORIGINS=
KEHRNEL_RATE_LIMIT=60
KEHRNEL_RATE_LIMIT_MAX_CLIENTS=5000
KEHRNEL_MAX_QUERY_RESULTS=1000
KEHRNEL_MAX_QUERY_TIME_MS=15000
KEHRNEL_MAX_STORED_QUERY_LIST=500
KEHRNEL_MAX_UPLOAD_BYTES=10485760
KEHRNEL_MAX_OPT_BYTES=5242880
KEHRNEL_ENABLE_STRATEGY_LOAD=true

# ----------------------------------------------------------------------------
# 3) Runtime behavior
# ----------------------------------------------------------------------------
KEHRNEL_DEBUG=false
KEHRNEL_REGISTRY_PATH=.kehrnel_registry.json
# KEHRNEL_STRATEGY_PATHS=./src/kehrnel/engine/strategies
KEHRNEL_API_HOST=0.0.0.0
KEHRNEL_API_PORT=8080
KEHRNEL_API_RELOAD=false

# ----------------------------------------------------------------------------
# 4) File/path safety switches (recommended for production)
# ----------------------------------------------------------------------------
KEHRNEL_ALLOW_LOCAL_FILE_INPUTS=false
KEHRNEL_ALLOW_ABSOLUTE_CONFIG_PATHS=false

# ----------------------------------------------------------------------------
# 5) Mongo TLS (optional; keep strict defaults)
# ----------------------------------------------------------------------------
KEHRNEL_MONGO_TLS_ALLOW_INVALID_CERTS=false
# KEHRNEL_MONGO_TLS_CA_FILE=
