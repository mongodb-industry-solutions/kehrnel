MONGODB_URI=<MONGODB URI>
MONGODB_DB=<MONGODB DATABASE>
TEST_DB_NAME=<MONGODB TESTING DATABASE>

# =============================================================================
# Security Configuration
# =============================================================================

# API Key Authentication
# Set to "true" to enable API key authentication
KEHRNEL_AUTH_ENABLED=false
# Comma-separated list of valid API keys (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
KEHRNEL_API_KEYS=

# CORS Configuration
# Comma-separated list of allowed origins, or "*" for all (development only)
# Leave empty for same-origin only (recommended for production)
KEHRNEL_CORS_ORIGINS=

# Rate Limiting
# Maximum requests per minute per client (0 to disable)
KEHRNEL_RATE_LIMIT=60