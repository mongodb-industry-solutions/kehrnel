FROM python:3.12-slim
WORKDIR /kerhnel

RUN apt-get update && apt-get install -y nodejs npm && rm -rf /var/lib/apt/lists/*
COPY docs/website/package*.json docs/website/
RUN cd docs/website && npm install
COPY docs/website/ docs/website/
RUN cd docs/website && npm run build

COPY . .
RUN pip install -e .[all]
ENV API_PORT=8080
ENV KEHRNEL_API_PORT=8080
ENV KEHRNEL_API_RELOAD=false
CMD ["kehrnel-api"]
EXPOSE 8080
