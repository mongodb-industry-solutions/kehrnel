                <term_definitions code="at0000">
                    <items id="text">HADS (Hospital Anxiety and Depression Scale)</items>
                    <items id="description">14-item screening scale with two 7-item subscales (Anxiety and Depression). Each item is scored 0–3; higher scores indicate greater symptom severity. Subscales range 0–21 and the total score 0–42.</items>
                </term_definitions>
