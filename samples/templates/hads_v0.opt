                <items id="description"></items>
            </items>
            <items code="at0169">
                <items id="text">Muy a menudo</items>
                <items id="description"></items>
            </items>
            <items code="at0175">
                <items id="text">P11. Me siento inquieto, como si tuviera que estar en movimiento</items>
                <items id="description">Subescala: Ansiedad</items>
            </items>
            <items code="at0176">
                <items id="text">Nada</items>
                <items id="description"></items>
            </items>
            <items code="at0177">
                <items id="text">No mucho</items>
                <items id="description"></items>
            </items>
            <items code="at0178">
                <items id="text">Bastante</items>
                <items id="description"></items>
            </items>
            <items code="at0179">
                <items id="text">Mucho</items>
                <items id="description"></items>
            </items>
            <items code="at0185">
                <items id="text">P13. Me asaltan repentinos sentimientos de pánico</items>
                <items id="description">Subescala: Ansiedad</items>
            </items>
            <items code="at0186">
                <items id="text">Nada</items>
                <items id="description"></items>
            </items>
            <items code="at0187">
                <items id="text">No muy a menudo</items>
                <items id="description"></items>
            </items>
            <items code="at0188">
                <items id="text">Bastante a menudo</items>
                <items id="description"></items>
            </items>
            <items code="at0189">
                <items id="text">Muy frecuentemente</items>
                <items id="description"></items>
            </items>
            <items code="at0120">
                <items id="text">P2. Todavía disfruto de las cosas que antes me gustaban</items>
                <items id="description">Subescala: Depresión</items>
            </items>
            <items code="at0121">
                <items id="text">Tanto como antes</items>
                <items id="description"></items>
            </items>
            <items code="at0122">
                <items id="text">Algo menos que antes</items>
                <items id="description"></items>
            </items>
            <items code="at0123">
                <items id="text">Sólo un poco</items>
                <items id="description"></items>
            </items>
            <items code="at0124">
                <items id="text">Casi nada</items>
                <items id="description"></items>
            </items>
            <items code="at0130">
                <items id="text">P4. Puedo reírme y ver el lado divertido de las cosas</items>
                <items id="description">Subescala: Depresión</items>
            </items>
            <items code="at0131">
                <items id="text">Tanto como siempre</items>
                <items id="description"></items>
