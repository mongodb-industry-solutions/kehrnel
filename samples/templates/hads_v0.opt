                </term_definitions>
                <term_definitions code="at0126">
                    <items id="text">Not at all</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0127">
                    <items id="text">A little, but it doesn't worry me</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0128">
                    <items id="text">Yes, but not too badly</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0129">
                    <items id="text">Very definitely and quite badly</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0135">
                    <items id="text">Q5. Worrying thoughts go through my mind</items>
                    <items id="description">Subscale: Anxiety</items>
                </term_definitions>
                <term_definitions code="at0136">
                    <items id="text">Only occasionally</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0137">
                    <items id="text">From time to time, but not too often</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0138">
                    <items id="text">A lot of the time</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0139">
                    <items id="text">A great deal of the time</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0145">
                    <items id="text">Q7. I can sit at ease and feel relaxed</items>
