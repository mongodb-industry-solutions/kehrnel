                <term_definitions code="at0149">
                    <items id="text">Not at all</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0165">
                    <items id="text">Q9. I get a sort of frightened feeling like 'butterflies' in the stomach</items>
