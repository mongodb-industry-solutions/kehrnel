                <items id="description"></items>
            </items>
            <items code="at0119">
                <items id="text">La mayor parte del tiempo</items>
                <items id="description"></items>
            </items>
            <items code="at0125">
                <items id="text">P3. Tengo una sensación de miedo, como si algo horrible fuera a suceder</items>
                <items id="description">Subescala: Ansiedad</items>
            </items>
            <items code="at0126">
                <items id="text">Nada</items>
                <items id="description"></items>
            </items>
            <items code="at0127">
                <items id="text">Un poco, pero no me preocupa</items>
                <items id="description"></items>
            </items>
            <items code="at0128">
                <items id="text">Sí, pero no demasiado</items>
                <items id="description"></items>
            </items>
            <items code="at0129">
                <items id="text">Muy claramente y bastante mal</items>
                <items id="description"></items>
            </items>
            <items code="at0135">
                <items id="text">P5. Mi mente se llena de preocupaciones</items>
                <items id="description">Subescala: Ansiedad</items>
            </items>
            <items code="at0136">
                <items id="text">Sólo ocasionalmente</items>
                <items id="description"></items>
            </items>
            <items code="at0137">
                <items id="text">De vez en cuando, pero no muy a menudo</items>
                <items id="description"></items>
            </items>
            <items code="at0138">
                <items id="text">Con bastante frecuencia</items>
                <items id="description"></items>
            </items>
            <items code="at0139">
                <items id="text">La mayor parte del tiempo</items>
                <items id="description"></items>
            </items>
            <items code="at0145">
                <items id="text">P7. Puedo estar sentado cómodamente y sentirme relajado</items>
                <items id="description">Subescala: Ansiedad</items>
            </items>
            <items code="at0146">
                <items id="text">Definitivamente</items>
                <items id="description"></items>
            </items>
            <items code="at0147">
                <items id="text">Por lo general</items>
                <items id="description"></items>
            </items>
            <items code="at0148">
                <items id="text">No muy a menudo</items>
                <items id="description"></items>
            </items>
            <items code="at0149">
                <items id="text">Nada</items>
                <items id="description"></items>
            </items>
            <items code="at0165">
                <items id="text">P9. Siento una especie de “mariposas” en el estómago</items>
                <items id="description">Subescala: Ansiedad</items>
            </items>
            <items code="at0166">
