            <items code="at0110">
                <items id="text">Interpretación HADS</items>
                <items id="description">Ranura para CLUSTER.hads_interpretation.v0</items>
            </items>
            <items code="at0195">
                <items id="text">Observaciones</items>
                <items id="description"></items>
            </items>
            <items code="at0000">
                <items id="text">HADS (Escala Hospitalaria de Ansiedad y Depresión)</items>
                <items id="description">Escala de cribado de 14 ítems con dos subescalas de 7 ítems (Ansiedad y Depresión). Cada ítem se puntúa 0–3; puntuaciones más altas indican mayor gravedad. Las subescalas van de 0–21 y la puntuación total de 0–42.</items>
            </items>
        </term_definitions>
    </component_ontologies>
    <component_ontologies archetype_id="openEHR-EHR-CLUSTER.hads_anxiety_interpretation.v0">
        <term_definitions language="es">
            <items code="at0001">
                <items id="text">Interpretación (Ansiedad)</items>
                <items id="description">Basada en la puntuación de la subescala de Ansiedad (0–21).</items>
                <items id="comment">Existe consenso respecto a que los cuestionarios con menos del 50% de respuestas en sus correspondientes dimensiones tienen demasiado sesgo para ser incluidos. Por ello requerimos este porcentaje mínimo de respuestas 
(https://pubmed.ncbi.nlm.nih.gov/27770833/</items>
            </items>
            <items code="at0002">
                <items id="text">Normal (0–7)</items>
                <items id="description"></items>
            </items>
            <items code="at0003">
                <items id="text">Límite anormal (8–10)</items>
                <items id="description"></items>
            </items>
            <items code="at0004">
                <items id="text">Anormal (11–21)</items>
                <items id="description"></items>
            </items>
            <items code="at0000">
                <items id="text">Interpretación HADS - Ansiedad</items>
                <items id="description">Banda de interpretación para la subescala de Ansiedad del HADS.</items>
            </items>
        </term_definitions>
    </component_ontologies>
    <component_ontologies archetype_id="openEHR-EHR-CLUSTER.hads_depression_interpretation.v0">
