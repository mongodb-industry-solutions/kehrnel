                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0189">
                    <items id="text">Very often indeed</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0120">
                    <items id="text">Q2. I still enjoy the things I used to enjoy</items>
                    <items id="description">Subscale: Depression</items>
                </term_definitions>
                <term_definitions code="at0121">
                    <items id="text">Definitely as much</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0122">
                    <items id="text">Not quite so much</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0123">
