                <items id="description"></items>
            </items>
            <items code="at0162">
                <items id="text">A veces</items>
                <items id="description"></items>
            </items>
            <items code="at0163">
                <items id="text">Muy a menudo</items>
                <items id="description"></items>
            </items>
            <items code="at0164">
                <items id="text">Casi todo el tiempo</items>
                <items id="description"></items>
            </items>
            <items code="at0170">
                <items id="text">P10. He perdido interés por mi aspecto personal</items>
                <items id="description">Subescala: Depresión</items>
            </items>
            <items code="at0171">
                <items id="text">Me cuido tanto como siempre</items>
                <items id="description"></items>
            </items>
            <items code="at0172">
                <items id="text">Puede que no me cuide tanto</items>
                <items id="description"></items>
            </items>
            <items code="at0173">
                <items id="text">No me cuido tanto como debería</items>
                <items id="description"></items>
            </items>
            <items code="at0174">
                <items id="text">Definitivamente</items>
                <items id="description"></items>
            </items>
            <items code="at0180">
                <items id="text">P12. Espero con agrado las cosas futuras</items>
                <items id="description">Subescala: Depresión</items>
            </items>
            <items code="at0181">
