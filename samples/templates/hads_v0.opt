                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0124">
                    <items id="text">Hardly at all</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0130">
                    <items id="text">Q4. I can laugh and see the funny side of things</items>
