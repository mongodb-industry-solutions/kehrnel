                <items id="description"></items>
            </items>
            <items code="at0184">
                <items id="text">Casi nada</items>
                <items id="description"></items>
            </items>
            <items code="at0190">
                <items id="text">P14. Disfruto con un buen libro, la radio o la televisión</items>
                <items id="description">Subescala: Depresión</items>
            </items>
            <items code="at0191">
