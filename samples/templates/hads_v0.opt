                <items id="description"></items>
            </items>
            <items code="at0134">
                <items id="text">Nada</items>
                <items id="description"></items>
            </items>
            <items code="at0140">
                <items id="text">P6. Me siento alegre</items>
                <items id="description">Subescala: Depresión</items>
            </items>
            <items code="at0141">
                <items id="text">La mayor parte del tiempo</items>
                <items id="description"></items>
            </items>
            <items code="at0142">
                <items id="text">A veces</items>
                <items id="description"></items>
            </items>
            <items code="at0143">
