<archetype_id>
    <value>openEHR-EHR-CLUSTER.hads_anxiety_interpretation.v0</value>
</archetype_id>
<term_definitions code="at0001">
    <items id="text">Interpretation (Anxiety)</items>
    <items id="description">Based on the Anxiety subscale score (0–21).</items>
    <items id="comment">There is consensus that questionnaires with less than 50% of responses in their corresponding dimensions 
have too much bias to be included. Therefore, this minimum percentage of responses is required 
(https://pubmed.ncbi.nlm.nih.gov/27770833/</items>
</term_definitions>
<term_definitions code="at0002">
    <items id="text">Normal (0–7)</items>
    <items id="description"></items>
</term_definitions>
<term_definitions code="at0003">
    <items id="text">Borderline abnormal (8–10)</items>
    <items id="description"></items>
</term_definitions>
<term_definitions code="at0004">
    <items id="text">Abnormal (11–21)</items>
    <items id="description"></items>
</term_definitions>
<term_definitions code="at0000">
    <items id="text">HADS Anxiety interpretation</items>
    <items id="description">Interpretation band for the HADS Anxiety subscale.</items>
</term_definitions>
