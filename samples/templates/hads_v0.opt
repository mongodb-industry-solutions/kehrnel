                </term_definitions>
                <term_definitions code="at0115">
                    <items id="text">Q1. I feel nervous or 'wound up'</items>
                    <items id="description">Subscale: Anxiety</items>
                </term_definitions>
                <term_definitions code="at0116">
                    <items id="text">Not at all</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0117">
                    <items id="text">From time to time, occasionally</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0118">
                    <items id="text">A lot of the time</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0119">
                    <items id="text">Most of the time</items>
                    <items id="description"></items>
                </term_definitions>
                <term_definitions code="at0125">
                    <items id="text">Q3. I get a sort of frightened feeling as if something awful is about to happen</items>
