        "strategy": {
          "schema": "schema.json",
          "defaults": "defaults.json",
          "description": "Data model and storage configuration (portal-visible)"
        },
        "bulk": {
          "schema": "ingest/bulk_schema.json",
          "defaults": "ingest/bulk_defaults.json",
          "description": "Bulk operation settings (CLI/API only, not visible in portal)"
        }
      },
      "pack_spec": {
        "$schema": "https://example.org/strategy-pack/spec.schema.json",
        "meta": {
          "strategyId": "openehr.rps_dual",
          "specVersion": "1.1",
          "title": "Reversed Path Search - Dual Collection",
          "summary": "Logical openEHR dual-store model with configurable physical encodings.",
          "domain": "openEHR",
          "tags": [
            "openEHR",
            "reversed-path",
            "dual-collection",
            "atlas-search",
            "semi-flatten"
          ],
          "owners": [
            "Francesc Mateu Amengual"
          ],
          "compat": {
            "packFormat": "strategy-pack/v1",
            "requires": [
              "storage.mongo"
            ],
            "optional": [
              "search.atlas",
              "search.lucene"
            ],
            "minRuntime": "0.9.0"
          }
        },
        "glossary": {
          "terms": {
            "canonical": "Lossless representation of the source clinical document.",
            "node": "A semi-flattened locatable subtree with lineage + payload.",
            "reversedPath": "A path encoded leaf-to-root to allow prefix matching for unknown depth CONTAINS chains.",
            "projection": "A derived record containing only the attributes required for a specific workload (e.g., cross-patient filters)."
          }
        },
        "logicalModel": {
          "source": {
            "types": [
              {
                "id": "openehr.composition.envelope.v1",
                "title": "Composition Envelope",
                "kind": "document",
                "description": "Headers plus a composition payload.",
                "fields": {
                  "ehr_id": {
                    "type": "string|uuid",
                    "role": "identity.patient"
                  },
                  "composition_uid": {
                    "type": "string|uuid",
                    "role": "identity.document"
                  },
                  "template_id": {
                    "type": "string",
                    "role": "identity.template"
                  },
                  "version": {
                    "type": "string|number",
                    "role": "version"
                  },
                  "ingest_time": {
                    "type": "date",
                    "role": "event.time"
                  },
                  "payload": {
                    "type": "json",
                    "path": "$.composition",
                    "role": "payload"
                  }
                }
              }
            ]
          },
          "concepts": [
            {
              "id": "openehr.node.v1",
              "title": "Flattened Node",
              "kind": "record",
              "meaning": "Flattened locatable subtree with lineage + payload.",
              "fields": {
                "p": {
                  "type": "string",
                  "role": "path.reversed",
                  "required": true
                },
                "kp": {
                  "type": "string[]",
                  "role": "path.keypath",
                  "required": false
                },
                "li": {
                  "type": "number",
                  "role": "lineage.listIndex",
                  "required": false
                },
                "data": {
                  "type": "json",
                  "role": "payload.fragment",
                  "required": true
                }
              }
            }
          ],
          "destinations": {
            "types": [
              {
                "id": "openehr.rps_dual.composition_nodes.v1",
                "title": "Semi-flattened compositions",
                "kind": "collectionRecord",
                "fields": {
                  "_id": {
                    "type": "objectId|uuid|string",
                    "role": "pk"
                  },
                  "ehr_id": {
                    "type": "string|uuid",
                    "role": "fk.patient",
                    "required": true
                  },
                  "comp_id": {
                    "type": "string|uuid",
                    "role": "identity.document"
                  },
                  "tid": {
                    "type": "string|number",
                    "role": "identity.template"
                  },
                  "v": {
                    "type": "string|number|null",
                    "role": "version"
                  },
                  "cn": {
                    "type": "openehr.node.v1[]",
                    "role": "nodes.canonical",
                    "required": true
                  }
                }
              },
              {
                "id": "openehr.rps_dual.search_nodes.v1",
                "title": "Slim projection for cross-patient search",
                "kind": "collectionRecord",
                "fields": {
                  "_id": {
                    "type": "objectId|uuid|string",
                    "role": "pk"
                  },
                  "ehr_id": {
                    "type": "string|uuid",
                    "role": "fk.patient",
                    "required": true
                  },
                  "tid": {
                    "type": "string|number",
                    "role": "identity.template"
                  },
                  "sort_time": {
                    "type": "date",
                    "role": "sort.primary",
                    "required": false
                  },
                  "sn": {
                    "type": "openehr.node.v1[]",
                    "role": "nodes.search",
                    "required": true
                  }
                }
              }
            ]
          }
        },
        "physicalProfiles": {
          "encodingProfiles": [
            {
              "id": "profile.fullpath",
              "title": "Full paths",
              "description": "Human readable paths (at-codes/archetype ids as strings).",
              "paths": {
                "mode": "full",
                "separator": "/",
                "order": "leaf_to_root"
              },
              "keys": {
                "mode": "verbatim"
              },
              "payload": {
                "mode": "full"
              },
              "dictionaries": {
                "at_codes": "optional",
                "archetype_ids": "optional"
              },
              "ids": {
                "ehr_id": "string",
                "composition_id": "string"
              }
            },
            {
              "id": "profile.codedpath",
              "title": "Coded paths",
              "description": "Numeric coded path segments using dictionary.",
              "paths": {
                "mode": "coded",
                "separator": ".",
                "order": "leaf_to_root",
                "dictRef": "bundles.dictionaries"
              },
              "keys": {
                "mode": "verbatim"
              },
              "payload": {
                "mode": "full"
              },
              "dictionaries": {
                "at_codes": "required",
                "archetype_ids": "optional"
              },
              "ids": {
                "ehr_id": "string|uuidBin",
                "composition_id": "string|uuidBin"
              }
            },
            {
              "id": "profile.search_shortcuts",
              "title": "Search shortcuts",
              "description": "Coded paths + key/value shortcuts + minimized payload.",
              "paths": {
                "mode": "coded",
                "separator": ".",
                "order": "leaf_to_root",
                "dictRef": "bundles.dictionaries"
              },
              "keys": {
                "mode": "shortcuts",
                "dictRef": "bundles.shortcuts"
              },
              "payload": {
                "mode": "minimized"
              },
              "ids": {
                "ehr_id": "string|uuidBin",
                "composition_id": "objectId|uuidBin|string"
              }
            }
          ]
        },
        "seeds": {
          "description": "Seed data for collections, referenced via file:// URIs in config",
          "codes": "file://bundles/dictionaries/_codes.json",
          "shortcuts": "file://bundles/shortcuts/shortcuts.json",
          "atlasSearchIndex": "file://bundles/searchIndex/searchIndex.json"
        },
        "storageModel": {
          "stores": [
            {
              "id": "store:compositions",
              "title": "Canonical compositions store",
              "engine": "mongo",
              "destinationType": "openehr.rps_dual.composition_nodes.v1",
              "collectionNameFromConfig": "collections.compositions.name",
              "encodingProfileFromConfig": "collections.compositions.encodingProfile",
              "indexes": [
                {
                  "id": "idx_patient_version",
                  "type": "btree",
                  "fields": [
                    "ehr_id",
                    "v"
                  ],
                  "purpose": "Patient-scoped retrieval + versioning"
                },
                {
                  "id": "idx_patient_path",
                  "type": "btree",
                  "fields": [
                    "ehr_id",
                    "cn.p"
                  ],
                  "purpose": "Fast patient-scoped path resolution (optional if too large)"
                }
              ]
            },
            {
              "id": "store:search",
              "title": "Slim search store",
              "engine": "mongo",
              "destinationType": "openehr.rps_dual.search_nodes.v1",
              "collectionNameFromConfig": "collections.search.name",
              "encodingProfileFromConfig": "collections.search.encodingProfile",
              "indexes": [
                {
                  "id": "idx_patient_sort",
                  "type": "btree",
                  "fields": [
                    "ehr_id",
                    "sort_time"
                  ],
                  "purpose": "Patient+time ordering, quick paging"
                }
              ],
              "search": {
                "kind": "atlas_search",
                "indexNameFromConfig": "collections.search.atlasIndex.name",
                "definitionFromConfig": "collections.search.atlasIndex.definition",
                "purpose": "Cross-patient filtered retrieval using embeddedDocument + wildcard/range"
              }
            },
            {
              "id": "store:codes",
              "title": "Codes Dictionary",
              "engine": "mongo",
              "collectionNameFromConfig": "collections.codes.name",
              "seedFromConfig": "collections.codes.seed",
              "modeFromConfig": "collections.codes.mode",
              "contains": [
                "at_codes",
                "archetype_ids"
              ],
              "purpose": "Coded path compaction (at-codes, archetype IDs)"
            },
            {
              "id": "store:shortcuts",
              "title": "Shortcuts Dictionary",
              "engine": "mongo",
              "collectionNameFromConfig": "collections.shortcuts.name",
              "seedFromConfig": "collections.shortcuts.seed",
              "purpose": "Short field keys for slim search payloads"
            }
          ]
        },
        "transformModel": {
          "pipeline": [
            {
              "id": "step.flatten",
              "op": "flatten_document_to_nodes",
              "title": "Flatten composition to nodes",
              "in": "logicalModel.source.types[0].fields.payload",
              "out": "nodes_full",
              "params": {
                "nodeConcept": "openehr.node.v1",
                "pathMode": "fromEncodingProfile.paths",
                "emit": [
                  "p",
                  "kp",
                  "li",
                  "data"
                ],
                "includeRootNode": true
              },
              "visual": {
                "group": "Transform",
                "icon": "layers",
                "notes": "Produces one node per locatable subtree + essential lineage metadata."
              }
            },
            {
              "id": "step.materialize.cn",
              "op": "materialize",
              "title": "Write compositions store",
              "toStore": "store:compositions",
              "nodeArrayField": "cn",
              "from": "nodes_full",
              "extraFields": [
                {
                  "field": "ehr_id",
                  "from": "$.headers.ehr_id"
                },
                {
                  "field": "comp_id",
                  "from": "$.headers.composition_uid"
                },
                {
                  "field": "tid",
                  "from": "$.headers.template_id"
                },
                {
                  "field": "v",
                  "from": "$.headers.version"
                }
              ],
              "visual": {
                "group": "Materialize",
                "icon": "database",
                "notes": "Canonical/semi-flattened record that supports projections and fidelity."
              }
            },
            {
              "id": "step.project.search",
              "op": "project_search_nodes",
              "title": "Build slim search nodes",
              "from": "nodes_full",
              "out": "nodes_search",
              "params": {
                "mappingsFromConfig": "transform.mappings",
                "payloadMode": "fromEncodingProfile.payload",
                "keysMode": "fromEncodingProfile.keys",
                "pathMode": "fromEncodingProfile.paths"
              },
              "visual": {
                "group": "Transform",
                "icon": "filter",
                "notes": "Keeps only the attributes required for cross-patient predicates/sorting."
              }
            },
            {
              "id": "step.materialize.sn",
              "op": "materialize",
              "title": "Write search store",
              "toStore": "store:search",
              "nodeArrayField": "sn",
              "from": "nodes_search",
              "extraFields": [
                {
                  "field": "ehr_id",
                  "from": "$.headers.ehr_id"
                },
                {
                  "field": "tid",
                  "from": "$.headers.template_id"
                },
                {
                  "field": "sort_time",
                  "from": "projection.sortTime",
                  "optional": true
                }
              ],
              "visual": {
                "group": "Materialize",
                "icon": "database",
                "notes": "Slim record optimized for Atlas Search indexing and cross-patient filters."
              }
            }
          ],
          "invariants": [
            {
              "id": "inv.keys",
              "title": "Stable join key",
              "assert": "store:compositions._id == store:search._id",
              "why": "Allows fast $lookup / hydration back to canonical docs."
            },
            {
              "id": "inv.patient",
              "title": "Patient scope preserved",
              "assert": "ehr_id present in all destination records",
              "why": "Allows patient-scoped queries without search engine."
            }
          ]
        },
        "queryModel": {
          "modes": [
            {
              "id": "patient_scoped",
              "title": "Patient-scoped",
              "uses": [
                "store:compositions"
              ],
              "pattern": "match",
              "primaryFilters": [
                "ehr_id"
              ],
              "pathPredicate": {
                "field": "cn.p",
                "operator": "regex|prefix|equals"
              },
              "notes": "Prefer B-tree / shard-local filtering when patient context is known."
            },
            {
              "id": "cross_patient",
              "title": "Cross-patient",
              "uses": [
                "store:search"
              ],
              "pattern": "search",
              "searchEngine": "atlas_search",
              "pathPredicate": {
                "field": "sn.p",
                "operator": "wildcard|equals"
              },
              "notes": "Use slim search docs for range/equality filters + sorting + limit."
            }
          ]
        },
        "samples": {
          "inputs": [
            "samples/composition.envelope.json"
          ],
          "outputs": {
            "store:compositions": [
              "samples/compositions.fullpath.json",
              "samples/compositions.codedpath.json"
            ],
            "store:search": [
              "samples/search.shortcuts.json"
            ]
          },
          "scenarios": [
            {
              "id": "scenario.vaccination",
              "title": "Vaccination list",
              "inputRef": "samples/composition.envelope.json",
              "show": [
                "transformGraph",
                "collectionModel",
                "pathLegend"
              ]
            }
          ]
        },
        "visualization": {
