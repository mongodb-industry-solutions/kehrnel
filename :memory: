                  "type": "free"
                }
              }
            ]
          },
          "collectionModel": {
            "entities": [
              {
                "id": "coll.compositions",
                "kind": "collection",
                "store": "store:compositions",
                "label": "compositions",
                "fields": [
                  "_id",
                  "ehr_id",
                  "comp_id",
                  "tid",
                  "v",
                  "cn"
                ],
                "expand": {
                  "cn": [
                    "p",
                    "kp",
