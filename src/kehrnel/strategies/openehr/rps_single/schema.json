{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "openEHR RPS-Single configuration",
  "description": "Configure single collection reversed-path storage and search.",
  "properties": {
    "database": { "type": "string", "description": "Database name to use for all collections" },
    "collections": {
      "type": "object",
      "description": "Collection names and collection-specific options",
      "properties": {
        "compositions": {
          "type": "object",
          "description": "Canonical composition storage",
          "properties": {
            "name": { "type": "string", "description": "Collection name for canonical compositions" },
            "store_canonical": { "type": "boolean", "description": "Persist original composition JSON" },
            "nodes_field": { "type": "string", "description": "Field that stores flattened nodes array" },
            "reverse_paths": { "type": "boolean", "description": "Store reversed AQL paths" },
            "store_nodes": { "type": "boolean", "description": "Persist flattened node documents" }
          },
          "required": ["name"]
        },
        "search": {
          "type": "object",
          "description": "Optional Atlas Search use against the same collection",
          "properties": {
            "enabled": { "type": "boolean", "description": "Enable Atlas Search queries" },
            "nodes_field": { "type": "string", "description": "Field that stores search nodes array" },
            "atlas_index_name": { "type": "string", "description": "Atlas Search index name" },
            "slim_projection": {
              "type": "object",
              "description": "Projection used to build slim search docs (if a slim view is created)",
              "additionalProperties": { "type": "string" }
            }
          }
        }
      },
      "required": ["compositions"]
    },
    "coding": {
      "type": "object",
      "description": "Dictionary configuration",
      "properties": {
        "archetype_ids": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "dictionary": { "type": "string" },
            "sequential": { "type": "boolean" }
          }
        },
        "atcodes": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "strategy": { "type": "string" },
            "store_original": { "type": "boolean" }
          }
        }
      }
    },
    "fields": {
      "type": "object",
      "description": "Field mapping for composition and search collections",
      "properties": {
        "composition": {
          "type": "object",
          "properties": {
            "nodes": { "type": "string" },
            "path": { "type": "string" },
            "archetype_path": { "type": "string" },
            "ehr_id": { "type": "string" },
            "comp_id": { "type": "string" }
          }
        },
        "search": {
          "type": "object",
          "properties": {
            "nodes": { "type": "string" },
            "path": { "type": "string" },
            "ehr_id": { "type": "string" },
            "comp_id": { "type": "string" }
          }
        }
      }
    },
    "node_representation": {
      "type": "object",
      "description": "Path formatting options",
      "properties": {
        "path": {
          "type": "object",
          "properties": {
            "mode": { "type": "string", "enum": ["reversed", "forward"] },
            "token_joiner": { "type": "string" }
          }
        }
      }
    },
    "query_engine": {
      "type": "object",
      "description": "Query planner options",
      "properties": {
        "mode": { "type": "string" },
        "search_first": { "type": "boolean" },
        "lookup_full_composition": { "type": "boolean" },
        "supports_multi_predicate": { "type": "boolean" }
      }
    }
  },
  "required": ["database", "collections", "fields"],
  "additionalProperties": true
}
