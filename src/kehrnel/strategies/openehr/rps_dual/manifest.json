{
  "id": "openehr.rps_dual",
  "name": "Reversed Path Search - Dual Collection",
  "version": "0.1.0",
  "summary": "Optimizes indexing with a slim search collection alongside canonical nodes.",
  "description": "Reference OpenEHR strategy using reversed paths, dual collections, and Atlas Search dual-mode querying.",
  "protocols": ["openEHR"],
  "capabilities": ["transform", "ingest", "validate", "query", "plan", "apply"],
  "entrypoint": "kehrnel.strategies.openehr.rps_dual.strategy:RPSDualStrategy",
  "ui": {
    "tags": ["openEHR", "dual-collection", "atlas-search"],
    "protocol_badge": "openEHR",
    "works_with": ["atlas_search_dual"],
    "links": {
      "docs": "docs/refactor-plan.md"
    }
  },
  "ops": [
  {
    "name": "ensure_dictionaries",
    "kind": "maintenance",
    "summary": "Ensure _codes/_shortcuts dictionaries exist",
    "input_schema": { "type": "object", "properties": {}, "additionalProperties": false },
    "output_schema": {
      "type": "object",
      "properties": {
        "codes_exists": { "type": "boolean" },
        "shortcuts_exists": { "type": "boolean" }
      }
    }
  },
  {
    "name": "rebuild_codes",
    "kind": "maintenance",
    "summary": "Rebuild atcode/archetype code tokens",
    "input_schema": {
      "type": "object",
      "properties": { "dry_run": { "type": "boolean", "default": false } },
      "additionalProperties": false
    },
    "output_schema": {
      "type": "object",
      "properties": {
        "updated": { "type": "boolean" },
        "min": { "type": "integer" },
        "max": { "type": "integer" },
        "counts": { "type": "object" }
      }
    }
  },
  {
    "name": "rebuild_shortcuts",
    "kind": "maintenance",
    "summary": "Rebuild slim shortcuts map",
    "input_schema": {
      "type": "object",
      "properties": { "dry_run": { "type": "boolean", "default": false } },
      "additionalProperties": false
    },
    "output_schema": { "type": "object" }
  },
  {
    "name": "ensure_atlas_search_index",
    "kind": "maintenance",
    "summary": "Ensure Atlas Search index for slim search collection",
    "input_schema": {
      "type": "object",
      "properties": {
        "index_name": { "type": "string" },
        "recreate": { "type": "boolean", "default": false }
      },
      "additionalProperties": false
    },
    "output_schema": {
      "type": "object",
      "properties": {
        "ok": { "type": "boolean" },
        "supported": { "type": "boolean" },
        "notes": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  {
    "name": "rebuild_slim_search_collection",
    "kind": "maintenance",
    "summary": "Recreate slim search docs from canonical compositions",
    "input_schema": {
      "type": "object",
      "properties": {
        "batch_size": { "type": "integer", "default": 2000 },
        "dry_run": { "type": "boolean", "default": false }
      },
      "additionalProperties": false
    },
    "output_schema": {
      "type": "object",
      "properties": {
        "processed": { "type": "integer" },
        "inserted": { "type": "integer" },
        "updated": { "type": "integer" },
        "warnings": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
],
  "adapters": {
    "storage": ["mongo"],
    "search": ["atlas_search"]
  }
}
