{
  "id": "openehr.rps_dual",
  "name": "Reversed Path Search - Dual Collection",
  "version": "0.2.0",
  "maturity": "published",
  "pack_format": "strategy-pack/v1",
  "spec": { "path": "spec.json", "version": "1.1" },
  "variants": ["composition.codedpath", "search.codedpath", "search.shortcuts"],
  "domain": "openEHR",
  "summary": "A balanced approach to clinical data storage that keeps your original records intact while enabling fast searches across your entire patient population.",
  "description": "This strategy preserves the complete clinical narrative in each patient record while maintaining a streamlined search layer for population health queries, research, and analytics.",
  "config": {
    "strategy": {
      "schema": "schema.json",
      "defaults": "defaults.json",
      "description": "Data model and storage configuration (portal-visible)"
    },
    "bulk": {
      "schema": "ingest/bulk_schema.json",
      "defaults": "ingest/bulk_defaults.json",
      "description": "Bulk operation settings (CLI/API only, not visible in portal)"
    }
  },
  "capabilities": [
    "transform",
    "ingest",
    "validate",
    "query",
    "synthetic",
    "plan",
    "apply"
  ],
  "entrypoint": "kehrnel.engine.strategies.openehr.rps_dual.strategy:RPSDualStrategy",
  "ui": {
    "tags": ["openEHR", "reversed-paths", "atlas-search", "dual-collection", "slim-search"],
    "domain_badge": "openEHR",
    "works_with": ["atlas_search_dual"],
    "docs": "/guide/docs/strategies/openehr/rps-dual",
    "links": {
      "strategy_base": "/api/strategies/openehr/rps_dual",
      "strategy_config": "/api/strategies/openehr/rps_dual/config",
      "strategy_ingest_body": "/api/strategies/openehr/rps_dual/ingest/body",
      "strategy_ingest_file": "/api/strategies/openehr/rps_dual/ingest/file",
      "strategy_ingest_database": "/api/strategies/openehr/rps_dual/ingest/database",
      "strategy_synthetic_generate": "/api/strategies/openehr/rps_dual/synthetic/generate",
      "strategy_synthetic_stats": "/api/strategies/openehr/rps_dual/synthetic/stats",
      "domain_base": "/api/domains/openehr",
      "domain_aql": "/api/domains/openehr/query/aql",
      "runtime_activate": "/environments/{env_id}/activate",
      "runtime_capabilities": "/environments/{env_id}/capabilities",
      "runtime_run": "/environments/{env_id}/run",
      "runtime_plan": "/environments/{env_id}/plan",
      "runtime_apply": "/environments/{env_id}/apply",
      "runtime_transform": "/environments/{env_id}/transform",
      "runtime_ingest": "/environments/{env_id}/ingest",
      "runtime_query": "/environments/{env_id}/query",
      "runtime_compile_query": "/environments/{env_id}/compile_query",
      "runtime_strategy_op": "/environments/{env_id}/activations/{domain}/ops/{op}",
      "runtime_synthetic_jobs": "/environments/{env_id}/synthetic/jobs",
      "runtime_synthetic_job": "/environments/{env_id}/synthetic/jobs/{job_id}",
      "runtime_synthetic_job_cancel": "/environments/{env_id}/synthetic/jobs/{job_id}/cancel",
      "strategy_manifest": "/strategies/openehr.rps_dual",
      "strategy_spec": "/strategies/openehr.rps_dual/spec",
      "strategy_endpoints": "/strategies/openehr.rps_dual/endpoints",
      "strategy_asset_paper": "/strategies/openehr.rps_dual/assets/rps-paper.pdf",
      "catalog_ops": "/ops"
    },
    "story": "Clinical teams need to access individual patient histories quickly and completely, while research and population health teams need to search across thousands of patients efficiently. This strategy solves both needs by storing the full clinical record for patient care, alongside a compact search layer optimized for population queries.\n\nWhen a clinician opens a patient chart, they get the complete record exactly as it was documented—every observation, every medication, every note preserved with full fidelity. When a researcher searches for patients with specific conditions, the system uses an optimized search layer to return results in seconds rather than minutes, without ever compromising the integrity of the source data.\n\nThe result is a single source of truth that serves both operational and analytical workloads. Clinical teams trust it for patient care because nothing is lost or transformed. Research teams trust it for population health because queries are fast and comprehensive. IT teams appreciate it because there's no ETL pipeline to maintain, no data warehouse to synchronize, and no risk of operational and analytical systems drifting apart.",
    "how_it_works": "Your data lives in two synchronized collections that work together seamlessly. The primary collection stores complete clinical documents—each composition preserved as a single document with every field, every nested structure, exactly as the source system created it. This collection is optimized for patient-scoped queries: when you need everything about one patient, the system retrieves it instantly using efficient B-tree indexes.\n\nThe search collection maintains a streamlined projection of the same data, purpose-built for population queries. It contains just enough information to find patients matching complex criteria—diagnoses, medications, lab values, dates—without the overhead of full document storage. Atlas Search indexes this collection, enabling sub-second queries across millions of records.\n\nThe system automatically routes each query to the right collection. Ask for a specific patient's records, and it goes to the primary collection. Search for all patients with a particular condition, and it uses the search collection. You write standard AQL queries; the routing happens transparently.",
    "benefits": [
      "Complete clinical records are preserved exactly as documented, supporting full audit trails, legal requirements, and the clinical fidelity that healthcare demands.",
      "Population searches run fast—cohort identification, quality metrics, and research queries complete in seconds even across large patient populations.",
      "You get a single system for both patient care and analytics, eliminating the ETL pipelines and data warehouses that traditionally create synchronization headaches and data drift.",
      "Standard AQL queries work seamlessly throughout, automatically routed to whichever storage layer serves them best."
    ],
    "ideal_for": "This strategy works best when your team needs both fast patient lookups and population-wide searches from the same data. It's particularly valuable when you want to run analytics directly on your operational data without maintaining separate systems, and when regulatory requirements demand that clinical records remain complete and unmodified. Healthcare organizations building clinical data repositories, research institutions conducting population health studies, and quality improvement teams tracking outcomes across patient cohorts all find this approach fits their needs.",
    "consider_alternatives": "If you only need patient-level queries without population searches, the simpler single-collection strategy may serve you better with less operational overhead. If Atlas Search is not available in your MongoDB deployment, you'll need to evaluate whether the population query capabilities justify the infrastructure requirements.",
    "scorecard": {
      "read_patient": 4,
      "read_population": 5,
      "writes": 2,
      "storage": 3,
      "index_cost": 3,
      "migration_ease": 2
    },
    "references": {
      "primary": [
        {
          "type": "paper",
          "title": "A Document-First openEHR Persistence Layer for Operational Patient and Cross-Patient Workloads",
          "authors": ["Mateu Amengual et al."],
          "venue": "IEEE",
          "year": 2025,
          "status": "peer-reviewed",
          "note": "Prepared for openEHR Conference 2025 call for papers (peer-reviewed).",
          "url": "https://arxiv.org/abs/XXXX.XXXXX",
          "asset": "assets/rps-paper.pdf"
        }
      ]
    },
    "tabs": {
      "overview": {
        "cards": [
          { "title": "Querying", "body": "Dual pipelines: $match for patient scope, $search for population with slim docs." },
          { "title": "Ingest", "body": "Stores canonical compositions and optional slim search documents." }
        ]
      }
    }
  },
  "ops": [
    {
      "name": "ensure_dictionaries",
      "kind": "maintenance",
      "summary": "Ensure and seed _codes/_shortcuts dictionaries",
      "input_schema": {
        "type": "object",
        "properties": {
          "codes": {
            "type": "string",
            "enum": ["none", "ensure", "seed"],
            "description": "Bootstrap mode for the codes dictionary"
          },
          "shortcuts": {
            "type": "string",
            "enum": ["none", "ensure", "seed"],
            "description": "Bootstrap mode for the shortcuts dictionary"
          }
        },
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "ok": { "type": "boolean" },
          "created": {
            "type": "array",
            "items": { "type": "string" }
          },
          "seeded": {
            "type": "object",
            "properties": {
              "codes": { "type": "integer" },
              "shortcuts": { "type": "integer" }
            }
          },
          "warnings": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    {
      "name": "rebuild_codes",
      "kind": "maintenance",
      "summary": "Rebuild code dictionary documents from configured seed payload",
      "input_schema": {
        "type": "object",
        "properties": {
          "dry_run": {
            "type": "boolean",
            "default": false
          }
        },
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "ok": { "type": "boolean" },
          "updated": { "type": "integer" },
          "warnings": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    {
      "name": "rebuild_shortcuts",
      "kind": "maintenance",
      "summary": "Rebuild shortcuts dictionary document from configured seed payload",
      "input_schema": {
        "type": "object",
        "properties": {
          "dry_run": {
            "type": "boolean",
            "default": false
          }
        },
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "ok": { "type": "boolean" },
          "updated": { "type": "integer" },
          "warnings": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    {
      "name": "build_search_index_definition",
      "kind": "maintenance",
      "summary": "Generate Atlas Search index definition from active mappings configuration",
      "input_schema": {
        "type": "object",
        "properties": {
          "include_stored_source": {
            "type": "boolean",
            "default": true
          }
        },
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "ok": { "type": "boolean" },
          "definition": { "type": "object" },
          "metadata": { "type": "object" },
          "warnings": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    {
      "name": "ensure_atlas_search_index",
      "kind": "maintenance",
      "summary": "Ensure Atlas Search index for slim search collection",
      "input_schema": {
        "type": "object",
        "properties": {
          "index_name": { "type": "string" },
          "recreate": {
            "type": "boolean",
            "default": false
          }
        },
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "ok": { "type": "boolean" },
          "result": { "type": "object" },
          "warnings": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    {
      "name": "rebuild_slim_search_collection",
      "kind": "maintenance",
      "summary": "Rebuild slim search docs from canonical compositions",
      "input_schema": {
        "type": "object",
        "properties": {
          "batch_size": {
            "type": "integer",
            "default": 100
          },
          "clear_existing": {
            "type": "boolean",
            "default": false
          }
        },
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "ok": { "type": "boolean" },
          "processed": { "type": "integer" },
          "inserted": { "type": "integer" },
          "cleared": { "type": "boolean" },
          "warnings": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    {
      "name": "synthetic_generate_batch",
      "kind": "synthetic",
      "summary": "Generate synthetic datasets in batch from source instances and/or model catalog",
      "input_schema": {
        "type": "object",
        "properties": {
          "patient_count": {
            "type": "integer",
            "minimum": 1
          },
          "patients": {
            "type": "integer",
            "minimum": 1
          },
          "source_collection": {
            "type": "string"
          },
          "source_database": {
            "type": "string"
          },
          "source_db": {
            "type": "string"
          },
          "source_templates": {
            "type": "array",
            "items": { "type": "string" }
          },
          "source_sample_size": {
            "type": "integer",
            "minimum": 1,
            "default": 200
          },
          "source_min_per_patient": {
            "type": "integer",
            "minimum": 0,
            "default": 1
          },
          "source_max_per_patient": {
            "type": "integer",
            "minimum": 0,
            "default": 1
          },
          "source_filter": {
            "type": "object",
            "additionalProperties": true
          },
          "generation_mode": {
            "type": "string",
            "enum": ["auto", "from_source", "from_models", "source", "models"]
          },
          "dry_run": {
            "type": "boolean",
            "default": false
          },
          "plan_only": {
            "type": "boolean",
            "default": false
          },
          "store_canonical": {
            "type": "boolean",
            "default": false
          },
          "canonical_collection": {
            "type": "string",
            "default": "compositions_canonical_synthetic"
          },
          "write_batch_size": {
            "type": "integer",
            "minimum": 10,
            "default": 250
          },
          "model_source": {
            "type": "object",
            "properties": {
              "database_name": { "type": "string" },
              "catalog_collection": { "type": "string" },
              "links_collection": { "type": "string" }
            },
            "additionalProperties": true
          },
          "models": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "properties": {
                "model_id": { "type": "string" },
                "template_id": { "type": "string" },
                "min_per_patient": { "type": "integer", "minimum": 0 },
                "max_per_patient": { "type": "integer", "minimum": 0 },
                "weight": { "type": "number", "minimum": 0 },
                "sample_pool_size": { "type": "integer", "minimum": 0, "default": 25 }
              },
              "required": ["model_id"],
              "additionalProperties": false
            }
          },
          "templates": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "properties": {
                "template_id": { "type": "string" },
                "templateId": { "type": "string" },
                "min_per_patient": {
                  "type": "integer",
                  "minimum": 0
                },
                "min": {
                  "type": "integer",
                  "minimum": 0
                },
                "max_per_patient": {
                  "type": "integer",
                  "minimum": 0
                },
                "max": {
                  "type": "integer",
                  "minimum": 0
                },
                "weight": {
                  "type": "number",
                  "minimum": 0
                },
                "sample_pool_size": {
                  "type": "integer",
                  "minimum": 0,
                  "default": 25
                }
              },
              "additionalProperties": false
            }
          },
          "links": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "from": { "type": "string" },
                "from_model_id": { "type": "string" },
                "to": { "type": "string" },
                "to_model_id": { "type": "string" },
                "probability": { "type": "number", "minimum": 0, "maximum": 1 },
                "min_to_per_patient": { "type": "integer", "minimum": 0 },
                "type": { "type": "string" }
              },
              "additionalProperties": true
            }
          }
        },
        "anyOf": [
          { "required": ["patient_count"] },
          { "required": ["patients"] }
        ],
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "ok": { "type": "boolean" },
          "dry_run": { "type": "boolean" },
          "plan_only": { "type": "boolean" },
          "source_collection": { "type": "string" },
          "source_database": { "type": ["string", "null"] },
          "target": {
            "type": "object",
            "properties": {
              "canonical": { "type": ["string", "null"] },
              "compositions": { "type": ["string", "null"] },
              "search": { "type": ["string", "null"] }
            }
          },
          "patients": { "type": "integer" },
          "estimated_docs": { "type": "integer" },
          "generated_docs": { "type": "integer" },
          "inserted_canonical": { "type": "integer" },
          "inserted_base": { "type": "integer" },
          "inserted_search": { "type": "integer" },
          "estimated_canonical_bytes": { "type": "integer" },
          "estimated_base_bytes": { "type": "integer" },
          "estimated_search_bytes": { "type": "integer" },
          "estimated_total_bytes": { "type": "integer" },
          "links_applied": { "type": "integer" },
          "models": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "model_id": { "type": "string" },
                "template_id": { "type": "string" },
                "min": { "type": "integer" },
                "max": { "type": "integer" }
              }
            }
          },
          "links": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "by_template": { "type": "object" },
          "by_model": { "type": "object" }
        }
      }
    }
  ],
  "adapters": {
    "storage": [
      "mongo"
    ],
    "search": [
      "atlas_search"
    ]
  }
}
