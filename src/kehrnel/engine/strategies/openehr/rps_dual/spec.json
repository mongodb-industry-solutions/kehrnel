{
  "$schema": "https://example.org/strategy-pack/spec.schema.json",
  "meta": {
    "strategyId": "openehr.rps_dual",
    "specVersion": "1.1",
    "title": "Reversed Path Search - Dual Collection",
    "summary": "Logical openEHR dual-store model with configurable physical encodings.",
    "domain": "openEHR",
    "tags": ["openEHR", "reversed-path", "dual-collection", "atlas-search", "semi-flatten"],
    "owners": ["Francesc Mateu Amengual"],
    "compat": {
      "packFormat": "strategy-pack/v1",
      "requires": ["storage.mongo"],
      "optional": ["search.atlas", "search.lucene"],
      "minRuntime": "0.9.0"
    }
  },

  "glossary": {
    "terms": {
      "canonical": "Lossless representation of the source clinical document.",
      "node": "A semi-flattened locatable subtree with lineage + payload.",
      "reversedPath": "A path encoded leaf-to-root to allow prefix matching for unknown depth CONTAINS chains.",
      "projection": "A derived record containing only the attributes required for a specific workload (e.g., cross-patient filters)."
    }
  },

  "logicalModel": {
    "source": {
      "types": [
        {
          "id": "openehr.composition.envelope.v1",
          "title": "Composition Envelope",
          "kind": "document",
          "description": "Headers plus a composition payload.",
          "fields": {
            "ehr_id": {"type": "string|uuid", "role": "identity.patient"},
            "composition_uid": {"type": "string|uuid", "role": "identity.document"},
            "template_id": {"type": "string", "role": "identity.template"},
            "version": {"type": "string|number", "role": "version"},
            "ingest_time": {"type": "date", "role": "event.time"},
            "payload": {"type": "json", "path": "$.composition", "role": "payload"}
          }
        }
      ]
    },

    "concepts": [
      {
        "id": "openehr.node.v1",
        "title": "Flattened Node",
        "kind": "record",
        "meaning": "Flattened locatable subtree with lineage + payload.",
        "fields": {
          "p": {"type": "string", "role": "path.reversed", "required": true},
          "kp": {"type": "string[]", "role": "path.keypath", "required": false},
          "pi": {"type": "number[]", "role": "lineage.pathInstance", "required": false},
          "data": {"type": "json", "role": "payload.fragment", "required": true}
        }
      }
    ],

    "destinations": {
      "types": [
        {
          "id": "openehr.rps_dual.composition_nodes.v1",
          "title": "Semi-flattened compositions",
          "kind": "collectionRecord",
          "fields": {
            "_id": {"type": "objectId|uuid|string", "role": "pk"},
            "ehr_id": {"type": "string|uuid", "role": "fk.patient", "required": true},
            "comp_id": {"type": "string|uuid", "role": "identity.document"},
            "tid": {"type": "string", "role": "identity.template"},
            "v": {"type": "string|number|null", "role": "version"},
            "time_c": {"type": "date", "role": "version.commit_time", "required": false},
            "cn": {"type": "openehr.node.v1[]", "role": "nodes.canonical", "required": true}
          }
        },
        {
          "id": "openehr.rps_dual.search_nodes.v1",
          "title": "Slim projection for cross-patient search",
          "kind": "collectionRecord",
          "fields": {
            "_id": {"type": "objectId|uuid|string", "role": "pk"},
            "ehr_id": {"type": "string|uuid", "role": "fk.patient", "required": true},
            "tid": {"type": "string", "role": "identity.template"},
            "sort_time": {"type": "date", "role": "sort.primary", "required": false},
            "sn": {"type": "openehr.node.v1[]", "role": "nodes.search", "required": true}
          }
        }
      ]
    }
  },

  "physicalProfiles": {
    "encodingProfiles": [
      {
        "id": "profile.fullpath",
        "title": "Full paths",
        "description": "Human readable paths (at-codes/archetype ids as strings).",
        "paths": {"mode": "full", "separator": "/", "order": "leaf_to_root"},
        "keys": {"mode": "verbatim"},
        "payload": {"mode": "full"},
        "dictionaries": {"at_codes": "optional", "archetype_ids": "optional"},
        "ids": {"ehr_id": "string", "composition_id": "string"}
      },
      {
        "id": "profile.codedpath",
        "title": "Coded paths",
        "description": "Numeric coded path segments using dictionary.",
        "paths": {"mode": "coded", "separator": ".", "order": "leaf_to_root", "dictRef": "bundles.dictionaries"},
        "keys": {"mode": "verbatim"},
        "payload": {"mode": "full"},
        "dictionaries": {"at_codes": "required", "archetype_ids": "optional"},
        "ids": {"ehr_id": "string|uuidBin", "composition_id": "string|uuidBin"}
      },
      {
        "id": "profile.search_shortcuts",
        "title": "Search shortcuts",
        "description": "Coded paths + key/value shortcuts + minimized payload.",
        "paths": {"mode": "coded", "separator": ".", "order": "leaf_to_root", "dictRef": "bundles.dictionaries"},
        "keys": {"mode": "shortcuts", "dictRef": "bundles.shortcuts"},
        "payload": {"mode": "minimized"},
        "ids": {"ehr_id": "string|uuidBin", "composition_id": "objectId|uuidBin|string"}
      }
    ]
  },

  "seeds": {
    "description": "Seed data for collections, referenced via file:// URIs in config",
    "codes": "file://bundles/dictionaries/_codes.json",
    "shortcuts": "file://bundles/shortcuts/shortcuts.json",
    "atlasSearchIndex": "file://bundles/searchIndex/searchIndex.json"
  },

  "storageModel": {
    "stores": [
      {
        "id": "store:compositions",
        "title": "Canonical compositions store",
        "engine": "mongo",
        "destinationType": "openehr.rps_dual.composition_nodes.v1",
        "collectionNameFromConfig": "collections.compositions.name",
        "encodingProfileFromConfig": "collections.compositions.encodingProfile",
        "indexes": [
          {
            "id": "idx_patient_version",
            "type": "btree",
            "fields": ["ehr_id", "v"],
            "purpose": "Patient-scoped retrieval + versioning"
          },
          {
            "id": "idx_patient_template_commit",
            "type": "btree",
            "fields": ["ehr_id", "tid", "time_c", "comp_id"],
            "purpose": "Patient-scoped template filtering plus version-time ordering"
          },
          {
            "id": "idx_patient_path",
            "type": "btree",
            "fields": ["ehr_id", "cn.p"],
            "purpose": "Fast patient-scoped path resolution (optional if too large)"
          }
        ]
      },
      {
        "id": "store:search",
        "title": "Slim search store",
        "engine": "mongo",
        "destinationType": "openehr.rps_dual.search_nodes.v1",
        "collectionNameFromConfig": "collections.search.name",
        "encodingProfileFromConfig": "collections.search.encodingProfile",
        "indexes": [
          {
            "id": "idx_patient_sort",
            "type": "btree",
            "fields": ["ehr_id", "sort_time"],
            "purpose": "Patient+time ordering, quick paging"
          }
        ],
        "search": {
          "kind": "atlas_search",
          "indexNameFromConfig": "collections.search.atlasIndex.name",
          "definitionFromConfig": "collections.search.atlasIndex.definition",
          "purpose": "Cross-patient filtered retrieval using embeddedDocument + wildcard/range"
        }
      },
      {
        "id": "store:codes",
        "title": "Codes Dictionary",
        "engine": "mongo",
        "collectionNameFromConfig": "collections.codes.name",
        "seedFromConfig": "collections.codes.seed",
        "contains": ["at_codes", "archetype_ids"],
        "purpose": "Coded path compaction (at-codes, archetype IDs)"
      },
      {
        "id": "store:shortcuts",
        "title": "Shortcuts Dictionary",
        "engine": "mongo",
        "collectionNameFromConfig": "collections.shortcuts.name",
        "seedFromConfig": "collections.shortcuts.seed",
        "purpose": "Short field keys for slim search payloads"
      }
    ]
  },

  "transformModel": {
    "pipeline": [
      {
        "id": "step.flatten",
        "op": "flatten_document_to_nodes",
        "title": "Flatten composition to nodes",
        "in": "logicalModel.source.types[0].fields.payload",
        "out": "nodes_full",
        "params": {
          "nodeConcept": "openehr.node.v1",
          "pathMode": "fromEncodingProfile.paths",
          "emit": ["p", "kp", "pi", "data"],
          "includeRootNode": true
        },
        "visual": {
          "group": "Transform",
          "icon": "layers",
          "notes": "Produces one node per locatable subtree + essential lineage metadata."
        }
      },
      {
        "id": "step.materialize.cn",
        "op": "materialize",
        "title": "Write compositions store",
        "toStore": "store:compositions",
        "nodeArrayField": "cn",
        "from": "nodes_full",
        "extraFields": [
          {"field": "ehr_id", "from": "$.headers.ehr_id"},
          {"field": "comp_id", "from": "$.headers.composition_uid"},
          {"field": "tid", "from": "$.headers.template_id"},
          {"field": "v", "from": "$.headers.version"},
          {"field": "time_c", "from": "$.headers.time_committed", "optional": true}
        ],
        "visual": {
          "group": "Materialize",
          "icon": "database",
          "notes": "Canonical/semi-flattened record that supports projections and fidelity."
        }
      },
      {
        "id": "step.project.search",
        "op": "project_search_nodes",
        "title": "Build slim search nodes",
        "from": "nodes_full",
        "out": "nodes_search",
        "params": {
          "mappingsFromConfig": "transform.mappings",
          "payloadMode": "fromEncodingProfile.payload",
          "keysMode": "fromEncodingProfile.keys",
          "pathMode": "fromEncodingProfile.paths"
        },
        "visual": {
          "group": "Transform",
          "icon": "filter",
          "notes": "Keeps only the attributes required for cross-patient predicates/sorting."
        }
      },
      {
        "id": "step.materialize.sn",
        "op": "materialize",
        "title": "Write search store",
        "toStore": "store:search",
        "nodeArrayField": "sn",
        "from": "nodes_search",
        "extraFields": [
          {"field": "ehr_id", "from": "$.headers.ehr_id"},
          {"field": "tid", "from": "$.headers.template_id"},
          {"field": "sort_time", "from": "$.headers.time_committed", "optional": true}
        ],
        "visual": {
          "group": "Materialize",
          "icon": "database",
          "notes": "Slim record optimized for Atlas Search indexing and cross-patient filters."
        }
      }
    ],

    "invariants": [
      {
        "id": "inv.keys",
        "title": "Stable join key",
        "assert": "store:compositions._id == store:search._id",
        "why": "Allows fast $lookup / hydration back to canonical docs."
      },
      {
        "id": "inv.patient",
        "title": "Patient scope preserved",
        "assert": "ehr_id present in all destination records",
        "why": "Allows patient-scoped queries without search engine."
      }
    ]
  },

  "queryModel": {
    "modes": [
      {
        "id": "patient_scoped",
        "title": "Patient-scoped",
        "uses": ["store:compositions"],
        "pattern": "match",
        "primaryFilters": ["ehr_id"],
        "pathPredicate": {"field": "cn.p", "operator": "regex|prefix|equals"},
        "notes": "Prefer B-tree / shard-local filtering when patient context is known."
      },
      {
        "id": "cross_patient",
        "title": "Cross-patient",
        "uses": ["store:search"],
        "pattern": "search",
        "searchEngine": "atlas_search",
        "pathPredicate": {"field": "sn.p", "operator": "wildcard|equals"},
        "notes": "Use slim search docs for range/equality filters + sorting + limit."
      }
    ]
  },

  "samples": {
    "inputs": ["samples/composition.envelope.json"],
    "outputs": {
      "store:compositions": [
        "samples/compositions.fullpath.json",
        "samples/compositions.codedpath.json"
      ],
      "store:search": [
        "samples/search.shortcuts.json"
      ]
    },
    "scenarios": [
      {
        "id": "scenario.vaccination",
        "title": "Vaccination list",
        "inputRef": "samples/composition.envelope.json",
        "show": ["transformGraph", "collectionModel", "pathLegend"]
      }
    ]
  },

  "visualization": {
    "canvas": {
      "defaultView": "overview",
      "views": [
        {
          "id": "overview",
          "title": "Overview",
          "shows": ["collectionModel", "transformGraph"],
          "layout": {"type": "grid", "columns": 2}
        },
        {
          "id": "collections",
          "title": "Collections",
          "shows": ["collectionModel"],
          "layout": {"type": "free"}
        },
        {
          "id": "transform",
          "title": "Transform",
          "shows": ["transformGraph"],
          "layout": {"type": "dag", "direction": "LR"}
        },
        {
          "id": "indexes",
          "title": "Indexes & Search",
          "shows": ["indexOverlay"],
          "layout": {"type": "free"}
        }
      ]
    },

    "collectionModel": {
      "entities": [
        {
          "id": "coll.compositions",
          "kind": "collection",
          "store": "store:compositions",
          "label": "compositions",
          "fields": ["_id", "ehr_id", "comp_id", "v", "time_c", "tid", "cn"],
          "expand": {
            "cn": ["p", "kp", "pi", "data"]
          },
          "badges": ["canonical", "patient", "hydration"],
          "links": [
            {"type": "joinsTo", "target": "coll.search", "on": "_id"}
          ]
        },
        {
          "id": "coll.search",
          "kind": "collection",
          "store": "store:search",
          "label": "search",
          "fields": ["_id", "ehr_id", "tid", "sort_time", "sn"],
          "expand": {
            "sn": ["p", "data"]
          },
          "badges": ["slim", "cross-patient", "search-indexed"],
          "links": [
            {"type": "joinsTo", "target": "coll.compositions", "on": "_id"}
          ]
        },
        {
          "id": "coll.codes",
          "kind": "collection",
          "store": "store:codes",
          "label": "_codes",
          "fields": ["_id", "_min", "_max", "at", "ar_code"],
          "badges": ["dictionary", "seed:file://"]
        },
        {
          "id": "coll.shortcuts",
          "kind": "collection",
          "store": "store:shortcuts",
          "label": "_shortcuts",
          "fields": ["_id", "keys", "values"],
          "badges": ["dictionary", "seed:file://"]
        }
      ]
    },

    "transformGraph": {
      "nodes": [
        {
          "id": "src.envelope",
          "kind": "source",
          "label": "Composition Envelope",
          "typeRef": "openehr.composition.envelope.v1"
        },
        {
          "id": "op.flatten",
          "kind": "transform",
          "label": "Flatten → nodes_full",
          "stepRef": "step.flatten"
        },
        {
          "id": "op.materialize.cn",
          "kind": "sink",
          "label": "Write compositions (cn)",
          "stepRef": "step.materialize.cn",
          "entityRef": "coll.compositions"
        },
        {
          "id": "op.project.search",
          "kind": "transform",
          "label": "Project → nodes_search",
          "stepRef": "step.project.search"
        },
        {
          "id": "op.materialize.sn",
          "kind": "sink",
          "label": "Write search (sn)",
          "stepRef": "step.materialize.sn",
          "entityRef": "coll.search"
        }
      ],
      "edges": [
        {"from": "src.envelope", "to": "op.flatten"},
        {"from": "op.flatten", "to": "op.materialize.cn"},
        {"from": "op.flatten", "to": "op.project.search"},
        {"from": "op.project.search", "to": "op.materialize.sn"}
      ]
    },

    "indexOverlay": {
      "indexGroups": [
        {
          "id": "idxgrp.compositions",
          "entityRef": "coll.compositions",
          "items": ["idx_patient_version", "idx_patient_path"]
        },
        {
          "id": "idxgrp.search",
          "entityRef": "coll.search",
          "items": ["idx_patient_sort"],
          "search": {"kind": "atlas_search", "ref": "bundles.atlas_search"}
        }
      ]
    },

    "legends": {
      "pathLegend": {
        "entries": [
          {"label": "p", "meaning": "reversed path (leaf → root)", "example": "at0014/at0007/.../COMPOSITION", "configPath": "fields.node.p"},
          {"label": "kp", "meaning": "key-path in JSON (for reconstruction/projection)", "example": "[\"context\",\"other_context\"]"},
          {"label": "pi", "meaning": "path instance chain (list indexes aligned with path segments)", "example": [0, -1, 2], "configPath": "fields.node.pi"},
          {"label": "data", "meaning": "node payload fragment", "example": "{\"value\": {...}}", "configPath": "fields.node.data"},
          {"label": "cn", "meaning": "canonical node array", "example": "composition nodes", "configPath": "fields.document.cn"},
          {"label": "sn", "meaning": "search node array", "example": "projection nodes", "configPath": "fields.document.sn"},
          {"label": "ehr_id", "meaning": "patient/EHR identifier", "example": "ehr-123", "configPath": "fields.document.ehr_id"},
          {"label": "comp_id", "meaning": "composition identifier", "example": "comp-456", "configPath": "fields.document.comp_id"},
          {"label": "tid", "meaning": "template identifier", "example": "PO_Obstetric_process_v0.8_FORMULARIS", "configPath": "fields.document.tid"},
          {"label": "v", "meaning": "composition version", "example": "1", "configPath": "fields.document.v"},
          {"label": "time_c", "meaning": "version commit time", "example": "2026-04-14T20:25:43.412Z", "configPath": "fields.document.time_committed"}
        ]
      },
      "uriLegend": {
        "entries": [
          {"scheme": "file://", "meaning": "Load from local file (relative to strategy root)", "example": "file://bundles/dictionaries/_codes.json"},
          {"scheme": "collection://", "meaning": "Load from MongoDB collection", "example": "collection://mappings"},
          {"scheme": "collection://?", "meaning": "Load with filter query", "example": "collection://mappings?template_id=vacc.v0"}
        ]
      }
    }
  }
}
